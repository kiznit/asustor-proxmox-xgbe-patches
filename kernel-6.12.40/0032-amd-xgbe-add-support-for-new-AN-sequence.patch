 	.enable_rrc			= 1,
+	.an_kr_workaround		= 1,
 };
 
 static struct xgbe_version_data xgbe_v2b = {
@@ -547,6 +550,7 @@ static struct xgbe_version_data xgbe_v2b = {
 	.rx_desc_prefetch		= 5,
